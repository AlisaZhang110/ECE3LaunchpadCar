#include <ECE3.h>
#include <stdio.h>

// Motor pins from your motor check code
const int left_nslp_pin  = 31;
const int right_nslp_pin = 11;
const int left_dir_pin   = 29;
const int right_dir_pin  = 30;
const int left_pwm_pin   = 40;
const int right_pwm_pin  = 39;

const int LED_RF = 75;

uint16_t sensorValues[8];
uint16_t sensorMin[8];
uint16_t sensorMax[8];

bool calibrated = false;

void setup() {
  ECE3_Init();

  pinMode(left_nslp_pin, OUTPUT);
  pinMode(left_dir_pin, OUTPUT);
  pinMode(left_pwm_pin, OUTPUT);
  pinMode(right_nslp_pin, OUTPUT);
  pinMode(right_dir_pin, OUTPUT);
  pinMode(right_pwm_pin, OUTPUT);
  pinMode(LED_RF, OUTPUT);

  // Keep motors disabled/off during calibration
  digitalWrite(left_nslp_pin, LOW);
  digitalWrite(right_nslp_pin, LOW);
  analogWrite(left_pwm_pin, 0);
  analogWrite(right_pwm_pin, 0);

  Serial.begin(9600);
  delay(1000);

  Serial.println("=== 8-SENSOR CALIBRATION ===");
  Serial.println("Move the car by hand over WHITE and BLACK parts of the track.");
  Serial.println("Calibration will run for 10 seconds.");
  Serial.println("After that, min/max and thresholds will be printed.");
  Serial.println();

  for (int i = 0; i < 8; i++) {
    sensorMin[i] = 65535;
    sensorMax[i] = 0;
  }

  digitalWrite(LED_RF, HIGH);
  calibrateSensors(10000);   // 10 seconds
  digitalWrite(LED_RF, LOW);

  printResults();
}

void loop() {
  // Keep showing live values after calibration
  read_IR(sensorValues);

  Serial.print("Raw: ");
  for (int i = 0; i < 8; i++) {
    Serial.print(sensorValues[i]);
    Serial.print("\t");
  }

  Serial.print(" | Norm: ");
  for (int i = 0; i < 8; i++) {
    int norm = normalizeSensor(i, sensorValues[i]);
    Serial.print(norm);
    Serial.print("\t");
  }

  Serial.println();
  delay(100);
}

void calibrateSensors(unsigned long durationMs) {
  unsigned long startTime = millis();

  while (millis() - startTime < durationMs) {
    read_IR(sensorValues);

    for (int i = 0; i < 8; i++) {
      if (sensorValues[i] < sensorMin[i]) sensorMin[i] = sensorValues[i];
      if (sensorValues[i] > sensorMax[i]) sensorMax[i] = sensorValues[i];
    }

    delay(5);
  }

  calibrated = true;
}

int normalizeSensor(int idx, uint16_t rawValue) {
  if (!calibrated) return 0;

  int range = sensorMax[idx] - sensorMin[idx];
  if (range <= 0) return 0;

  int norm = ((int)rawValue - sensorMin[idx]) * 1000 / range;

  if (norm < 0) norm = 0;
  if (norm > 1000) norm = 1000;

  return norm;
}

void printResults() {
  Serial.println();
  Serial.println("=== CALIBRATION COMPLETE ===");

  Serial.print("sensorMin = { ");
  for (int i = 0; i < 8; i++) {
    Serial.print(sensorMin[i]);
    if (i < 7) Serial.print(", ");
  }
  Serial.println(" };");

  Serial.print("sensorMax = { ");
  for (int i = 0; i < 8; i++) {
    Serial.print(sensorMax[i]);
    if (i < 7) Serial.print(", ");
  }
  Serial.println(" };");

  Serial.print("threshold = { ");
  for (int i = 0; i < 8; i++) {
    int threshold = (sensorMin[i] + sensorMax[i]) / 2;
    Serial.print(threshold);
    if (i < 7) Serial.print(", ");
  }
  Serial.println(" };");

  Serial.println();
  Serial.println("Use these values in your line-following code.");
  Serial.println("Move the car around and watch the live Raw/Norm readings.");
}